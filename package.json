{
    "name": "king-image-editor",
    "version": "1.0.0",
    "description": "King Image Editor — Desktop App",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build-win": "electron-builder --win",
        "build-mac": "electron-builder --mac",
        "build-linux": "electron-builder --linux"
    },
    "build": {
        "appId": "com.king.imageeditor",
        "productName": "King Image Editor",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "nsis",
            "icon": "icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "King Image Editor"
        }
    },
    "devDependencies": {
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "@capacitor-community/media": "^9.0.2",
        "@capacitor/android": "^8.1.0",
        "@capacitor/browser": "^8.0.1",
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "@capacitor/filesystem": "^8.1.2",
        "@capacitor/share": "^8.0.1"
    }
}
